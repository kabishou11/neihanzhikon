# 医疗内涵质控系统环境变量配置
# 复制为 .env 后使用

# ============ LLM 配置 ============
# LLM 客户端类型: modelscope / openai / local
LLM_CLIENT_TYPE=modelscope

# ModelScope 配置（必填）
MODELSCOPE_API_KEY=ms-your-api-key-here
MODELSCOPE_MODEL=Qwen/Qwen3.5-35B-A3B
MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1

# 推理参数（符合 Qwen3.5-35B 最佳实践）
# Temperature: 逻辑推理任务建议 0.1-0.3，创意任务 0.7-0.9
MODELSCOPE_TEMPERATURE=0.1
# Top-p: 与 temperature 配合，推理任务建议 0.8-0.9
MODELSCOPE_TOP_P=0.8
# Max tokens: 质控判断只需短输出，1024 足够
MODELSCOPE_MAX_TOKENS=1024
# Timeout: 单次调用超时（秒）
MODELSCOPE_TIMEOUT=90

# OpenAI 配置（可选，当 LLM_CLIENT_TYPE=openai 时使用）
# OPENAI_API_KEY=sk-your-key
# OPENAI_MODEL=gpt-3.5-turbo
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_TEMPERATURE=0.1
# OPENAI_MAX_TOKENS=2000

# 本地模型配置（可选，当 LLM_CLIENT_TYPE=local 时使用）
# LOCAL_BASE_URL=http://localhost:8000
# LOCAL_MODEL=qwen-30b
# LOCAL_TEMPERATURE=0.1
# LOCAL_MAX_TOKENS=2000

# ============ 服务配置 ============
# 并发线程数（30B 模型建议 2-3）
MAX_WORKERS=2

# 规则插件（逗号分隔）
PLUGIN_MODULES=fastapi_qc.plugins.cardiology_plugin

# ============ 质量保障配置 ============
# 最小置信度阈值
QA_MIN_CONFIDENCE=0.7

# 最大重试次数
QA_MAX_RETRIES=3

# 超时时间（秒）
QA_TIMEOUT=30

# 启用人工复核
QA_ENABLE_REVIEW=false

# 复核置信度阈值
QA_REVIEW_THRESHOLD=0.6
